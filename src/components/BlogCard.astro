---
interface Props {
  id: string
  title: string
  description: string
  pubDate: Date
  category: string
  tags: string[]
  hero?: string
}

const { id, title, description, pubDate, category, tags } = Astro.props

const categoryLabels: Record<string, string> = {
  "hero-guide": "ヒーロー攻略",
  "patch-notes": "パッチノート",
  meta: "メタ考察",
  "item-guide": "アイテムガイド",
  tips: "Tips",
}

const categoryColors: Record<string, string> = {
  "hero-guide": "text-hero-guide",
  "patch-notes": "text-patch-notes",
  meta: "text-meta",
  "item-guide": "text-item-guide",
  tips: "text-tips",
}

const formattedDate = pubDate.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
})
---

<article
  class="bg-bg-card rounded-lg border border-border hover:border-border-hover transition-colors p-6"
>
  <a href={`/blog/${id}`} class="block">
    <div class="flex items-center gap-3 mb-3">
      <span
        class={`text-xs font-semibold ${categoryColors[category] ?? "text-text-secondary"}`}
      >
        {categoryLabels[category] ?? category}
      </span>
      <time class="text-xs text-text-muted" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>
    <h2
      class="text-lg font-bold text-text-primary mb-2 hover:text-accent transition-colors"
    >
      {title}
    </h2>
    <p class="text-sm text-text-secondary line-clamp-2 mb-4">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <span class="text-xs bg-accent-subtle text-accent px-2 py-1 rounded">
            {tag}
          </span>
        ))
      }
    </div>
  </a>
</article>
