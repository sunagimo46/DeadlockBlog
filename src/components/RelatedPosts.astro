---
import BlogCard from "./BlogCard.astro"
import { calculateReadingTime } from "../lib/reading-time"
import { getSlug } from "../lib/posts"
import type { CollectionEntry } from "astro:content"

interface Props {
  posts: CollectionEntry<"blog">[]
}

const { posts } = Astro.props
---

{
  posts.length > 0 && (
    <section class="mt-12 pt-8 border-t border-border max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold mb-6">関連記事</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            slug={getSlug(post.id)}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            hero={post.data.hero}
            readingTime={
              post.body ? calculateReadingTime(post.body) : undefined
            }
          />
        ))}
      </div>
    </section>
  )
}
