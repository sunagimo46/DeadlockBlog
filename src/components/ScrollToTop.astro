<button
  id="scroll-to-top"
  class="fixed bottom-6 right-6 z-50 hidden p-3 bg-bg-card border border-border rounded-full text-text-secondary hover:text-accent hover:border-accent transition-colors shadow-lg cursor-pointer"
  aria-label="トップへ戻る"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M5 15l7-7 7 7"></path>
  </svg>
</button>

<script>
  const button = document.getElementById("scroll-to-top")
  if (button) {
    window.addEventListener("scroll", () => {
      button.classList.toggle("hidden", window.scrollY < 300)
    })
    button.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" })
    })
  }
</script>
